import javax.swing.*;
import javax.swing.border.AbstractBorder;
import java.awt.*;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;
import java.awt.Desktop;

public class ProfileWindow {
    private JFrame frame;
    private JFrame parentFrame;
    private Player player;

    public ProfileWindow(Player player) {
        this(player, null);
    }

    public ProfileWindow(Player player, JFrame parentFrame) {
        this.player = player;
        this.parentFrame = parentFrame;
        frame = new JFrame("👤 " + player.getUsername() + " - Profile");
        frame.setSize(500, 650);
        frame.setLocationRelativeTo(null);
        frame.setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);

        // Modern gradient background
        JPanel mainPanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                GradientPaint gradient = new GradientPaint(0, 0, new Color(34, 139, 87),
                        getWidth(), getHeight(), new Color(0, 150, 136));
                g2d.setPaint(gradient);
                g2d.fillRect(0, 0, getWidth(), getHeight());
            }
        };
        mainPanel.setLayout(new BorderLayout(15, 15));
        mainPanel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        frame.setContentPane(mainPanel);

        // Hide parent frame while profile is open
        if (parentFrame != null) {
            parentFrame.setVisible(false);
        }

        frame.addWindowListener(new java.awt.event.WindowAdapter() {
            @Override
            public void windowClosed(java.awt.event.WindowEvent e) {
                if (parentFrame != null) {
                    parentFrame.setVisible(true);
                }
            }
        });

        // Scroll Panel for content
        JPanel contentPanel = new JPanel();
        contentPanel.setLayout(new BoxLayout(contentPanel, BoxLayout.Y_AXIS));
        contentPanel.setOpaque(false);

        // Username Card
        JPanel usernameCard = createInfoCard("👤 Username", player.getUsername(), new Color(0, 150, 136));
        contentPanel.add(usernameCard);
        contentPanel.add(Box.createVerticalStrut(10));

        // Lichess Card
        if (player.getLichessUsername() != null && !player.getLichessUsername().isEmpty()) {
            JPanel lichessCard = new JPanel() {
                @Override
                protected void paintComponent(Graphics g) {
                    Graphics2D g2d = (Graphics2D) g;
                    g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                    g2d.setColor(new Color(255, 255, 255, 240));
                    g2d.fillRoundRect(0, 0, getWidth(), getHeight(), 15, 15);
                }
            };
            lichessCard.setOpaque(false);
            lichessCard.setLayout(new BorderLayout(10, 10));
            lichessCard.setBorder(BorderFactory.createEmptyBorder(12, 15, 12, 15));
            lichessCard.setMaximumSize(new Dimension(Integer.MAX_VALUE, 60));

            JLabel lichessLabel = new JLabel("♟ Lichess: " + player.getLichessUsername());
            lichessLabel.setFont(new Font("Segoe UI", Font.BOLD, 14));
            lichessLabel.setForeground(new Color(34, 139, 87));

            JButton updateBtn = new JButton("Update");
            updateBtn.setFont(new Font("Segoe UI", Font.BOLD, 11));
            updateBtn.setPreferredSize(new Dimension(80, 30));
            styleButtonProfile(updateBtn, new Color(0, 150, 136));
            updateBtn.addActionListener(e -> openLichessLinkDialog());

            lichessCard.add(lichessLabel, BorderLayout.CENTER);
            lichessCard.add(updateBtn, BorderLayout.EAST);
            contentPanel.add(lichessCard);
        } else {
            JButton linkBtn = new JButton("🔗 Link Lichess Account");
            styleButtonProfile(linkBtn, new Color(76, 175, 80));
            linkBtn.setFont(new Font("Segoe UI", Font.BOLD, 13));
            linkBtn.addActionListener(e -> openLichessLinkDialog());
            contentPanel.add(linkBtn);
        }

        contentPanel.add(Box.createVerticalStrut(15));

        // Stats Section
        JLabel statsLabel = new JLabel("📊 Game Stats");
        statsLabel.setFont(new Font("Segoe UI", Font.BOLD, 16));
        statsLabel.setForeground(Color.WHITE);
        contentPanel.add(statsLabel);
        contentPanel.add(Box.createVerticalStrut(10));

        contentPanel.add(createGameStatCard("♟ Chess", player.getChessStats(), new Color(100, 180, 255)));
        contentPanel.add(Box.createVerticalStrut(8));
        contentPanel.add(createGameStatCard("🧩 Logic", player.getLogicStats(), new Color(255, 180, 100)));
        contentPanel.add(Box.createVerticalStrut(8));
        contentPanel.add(createGameStatCard("🧠 Memory", player.getMemoryStats(), new Color(180, 255, 100)));

        JScrollPane scrollPane = new JScrollPane(contentPanel);
        scrollPane.setOpaque(false);
        scrollPane.getViewport().setOpaque(false);
        scrollPane.setBorder(null);
        mainPanel.add(scrollPane, BorderLayout.CENTER);

        // Bottom buttons
        JPanel bottomPanel = new JPanel();
        bottomPanel.setOpaque(false);
        bottomPanel.setLayout(new GridLayout(1, 2, 10, 10));

        JButton friendsBtn = new JButton("👥 View Friends");
        styleButtonProfile(friendsBtn, new Color(76, 175, 80));
        friendsBtn.addActionListener(e -> {
            frame.dispose();
            new FriendsWindow(player, parentFrame);
        });
        bottomPanel.add(friendsBtn);

        JButton closeBtn = new JButton("Close");
        styleButtonProfile(closeBtn, new Color(180, 100, 100));
        closeBtn.addActionListener(e -> frame.dispose());
        bottomPanel.add(closeBtn);

        mainPanel.add(bottomPanel, BorderLayout.SOUTH);

        // If parent frame is maximized, maximize this frame too
        if (parentFrame != null && (parentFrame.getExtendedState() & JFrame.MAXIMIZED_BOTH) != 0) {
            frame.setExtendedState(JFrame.MAXIMIZED_BOTH);
        }

        frame.setVisible(true);
    }

    private JPanel createInfoCard(String title, String value, Color bgColor) {
        JPanel card = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2d.setColor(new Color(255, 255, 255, 240));
                g2d.fillRoundRect(0, 0, getWidth(), getHeight(), 15, 15);
            }
        };
        card.setOpaque(false);
        card.setLayout(new BorderLayout(10, 10));
        card.setBorder(BorderFactory.createEmptyBorder(12, 15, 12, 15));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 60));

        JLabel titleLabel = new JLabel(title);
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        titleLabel.setForeground(bgColor);

        JLabel valueLabel = new JLabel(value);
        valueLabel.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        valueLabel.setForeground(new Color(50, 50, 50));

        JPanel textPanel = new JPanel(new GridLayout(2, 1));
        textPanel.setOpaque(false);
        textPanel.add(titleLabel);
        textPanel.add(valueLabel);

        card.add(textPanel, BorderLayout.CENTER);
        return card;
    }

    private JPanel createGameStatCard(String gameName, GameStats stats, Color color) {
        JPanel card = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                GradientPaint gradient = new GradientPaint(0, 0, color,
                        getWidth(), getHeight(), color.darker());
                g2d.setPaint(gradient);
                g2d.fillRoundRect(0, 0, getWidth(), getHeight(), 12, 12);
            }
        };
        card.setOpaque(false);
        card.setLayout(new BorderLayout(10, 10));
        card.setBorder(BorderFactory.createEmptyBorder(10, 12, 10, 12));
        card.setMaximumSize(new Dimension(Integer.MAX_VALUE, 50));

        JLabel gameLabel = new JLabel(gameName);
        gameLabel.setFont(new Font("Segoe UI", Font.BOLD, 13));
        gameLabel.setForeground(Color.WHITE);

        JLabel statsLabel = new JLabel("Played: " + stats.getTotalGames() + " | Won: " + stats.getTotalWins());
        statsLabel.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        statsLabel.setForeground(new Color(255, 255, 255, 200));

        JPanel textPanel = new JPanel(new GridLayout(2, 1));
        textPanel.setOpaque(false);
        textPanel.add(gameLabel);
        textPanel.add(statsLabel);

        card.add(textPanel, BorderLayout.CENTER);
        return card;
    }

    private void styleButtonProfile(JButton button, Color bgColor) {
        button.setFont(new Font("Segoe UI", Font.BOLD, 12));
        button.setForeground(Color.WHITE);
        button.setBackground(bgColor);
        button.setFocusPainted(false);
        button.setBorder(BorderFactory.createCompoundBorder(
                new RoundedBorderPW(8, bgColor),
                BorderFactory.createEmptyBorder(6, 12, 6, 12)));
        button.setCursor(new Cursor(Cursor.HAND_CURSOR));
        button.setOpaque(true);
        
        button.addMouseListener(new MouseAdapter() {
            @Override
            public void mouseEntered(MouseEvent e) {
                button.setBackground(bgColor.brighter());
            }
            @Override
            public void mouseExited(MouseEvent e) {
                button.setBackground(bgColor);
            }
        });
    }            JButton updateBtn = new JButton("Update Lichess Account");
            updateBtn.addActionListener(e -> openLichessLinkDialog());
            
            lichessPanel.add(lichessBtn);
            lichessPanel.add(updateBtn);
            top.add(lichessPanel);
        } else {
            JButton linkBtn = new JButton("Link Lichess Account");
            linkBtn.setForeground(Color.BLUE);
            linkBtn.addActionListener(e -> openLichessLinkDialog());
            top.add(linkBtn);
        }
        
        frame.add(top, BorderLayout.NORTH);

        // Center: stats and achievements
        JTextArea info = new JTextArea();
        info.setEditable(false);
        info.setFont(new Font("Monospaced", Font.PLAIN, 12));
        StringBuilder sb = new StringBuilder();
        sb.append("Chess: " + player.getChessStats().getTotalGames() + " games, " + player.getChessStats().getTotalWins() + " wins\n");
        sb.append("Logic: " + player.getLogicStats().getTotalGames() + " games, " + player.getLogicStats().getTotalWins() + " wins\n");
        sb.append("Memory: " + player.getMemoryStats().getTotalGames() + " games, " + player.getMemoryStats().getTotalWins() + " wins\n\n");
        sb.append("Achievements:\n");
        for (String a : player.getAchievements()) {
            sb.append(" - " + a + "\n");
        }
        sb.append("\nFriends:\n");
        for (String f : player.getFriends()) {
            sb.append(" - " + f + "\n");
        }
        info.setText(sb.toString());
        frame.add(new JScrollPane(info), BorderLayout.CENTER);

        // Bottom: friend buttons
        JPanel bottom = new JPanel();
        JButton addFriend = new JButton("Add Friend");
        addFriend.addActionListener(e -> {
            String name = JOptionPane.showInputDialog(frame, "Enter username to add:");
            if (name != null && !name.isEmpty()) {
                player.addFriend(name);
                info.append(" - " + name + "\n");
                DatabaseFactory.getDatabase().save();
            }
        });
        JButton removeFriend = new JButton("Remove Friend");
        removeFriend.addActionListener(e -> {
            String name = JOptionPane.showInputDialog(frame, "Enter username to remove:");
            if (name != null && !name.isEmpty()) {
                player.removeFriend(name);
                // rebuild info text
                StringBuilder sb2 = new StringBuilder();
                sb2.append(info.getText().split("Friends:")[0]);
                sb2.append("Friends:\n");
                for (String f : player.getFriends()) sb2.append(" - " + f + "\n");
                info.setText(sb2.toString());
                DatabaseFactory.getDatabase().save();
            }
        });
        bottom.add(addFriend);
        bottom.add(removeFriend);
        frame.add(bottom, BorderLayout.SOUTH);

        // If parent frame is maximized, maximize this frame too
        if (parentFrame != null && (parentFrame.getExtendedState() & JFrame.MAXIMIZED_BOTH) != 0) {
            frame.setExtendedState(JFrame.MAXIMIZED_BOTH);
        }

        frame.setVisible(true);
    }

    private void openLichessLinkDialog() {
        JDialog dialog = new JDialog(frame, "Link Lichess Account", true);
        dialog.setSize(350, 250);
        dialog.setLocationRelativeTo(frame);
        
        JPanel mainPanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                GradientPaint gradient = new GradientPaint(0, 0, new Color(34, 139, 87),
                        getWidth(), getHeight(), new Color(0, 150, 136));
                g2d.setPaint(gradient);
                g2d.fillRect(0, 0, getWidth(), getHeight());
            }
        };
        mainPanel.setLayout(new BorderLayout(10, 10));
        mainPanel.setBorder(BorderFactory.createEmptyBorder(15, 15, 15, 15));

        JLabel titleLabel = new JLabel("🔗 Link Lichess Account");
        titleLabel.setFont(new Font("Segoe UI", Font.BOLD, 16));
        titleLabel.setForeground(Color.WHITE);
        mainPanel.add(titleLabel, BorderLayout.NORTH);

        JPanel formPanel = new JPanel(new GridLayout(0, 1, 5, 5));
        formPanel.setOpaque(false);

        JLabel instructionLabel = new JLabel("<html>Enter your Lichess username.<br/>You only need to do this once!</html>");
        instructionLabel.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        instructionLabel.setForeground(new Color(200, 255, 230));
        formPanel.add(instructionLabel);

        JLabel usernameLabel = new JLabel("Lichess Username:");
        usernameLabel.setFont(new Font("Segoe UI", Font.BOLD, 12));
        usernameLabel.setForeground(Color.WHITE);
        formPanel.add(usernameLabel);

        JTextField usernameField = new JTextField(player.getLichessUsername() != null ? player.getLichessUsername() : "");
        usernameField.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        usernameField.setBorder(BorderFactory.createCompoundBorder(
                new RoundedBorderPW(8, new Color(200, 255, 255)),
                BorderFactory.createEmptyBorder(6, 10, 6, 10)));
        usernameField.setPreferredSize(new Dimension(250, 35));
        formPanel.add(usernameField);

        mainPanel.add(formPanel, BorderLayout.CENTER);

        JPanel buttonPanel = new JPanel(new GridLayout(1, 2, 10, 10));
        buttonPanel.setOpaque(false);
        buttonPanel.setBorder(BorderFactory.createEmptyBorder(10, 0, 0, 0));

        JButton saveButton = new JButton("Save & Continue");
        styleButtonProfile(saveButton, new Color(76, 175, 80));
        saveButton.addActionListener(e -> {
            String lichessUsername = usernameField.getText().trim();
            if (lichessUsername.isEmpty()) {
                JOptionPane.showMessageDialog(dialog, "Please enter a Lichess username.", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            
            player.setLichessUsername(lichessUsername);
            DatabaseFactory.getDatabase().save();
            dialog.dispose();
            
            frame.dispose();
            new ProfileWindow(player, parentFrame);
            
            JOptionPane.showMessageDialog(frame, 
                "✓ Lichess account linked successfully!\nUsername: " + lichessUsername, 
                "Success", 
                JOptionPane.INFORMATION_MESSAGE);
        });

        JButton cancelButton = new JButton("Cancel");
        styleButtonProfile(cancelButton, new Color(180, 100, 100));
        cancelButton.addActionListener(e -> dialog.dispose());

        buttonPanel.add(saveButton);
        buttonPanel.add(cancelButton);
        mainPanel.add(buttonPanel, BorderLayout.SOUTH);

        dialog.setContentPane(mainPanel);
        dialog.setVisible(true);
    }
}

// Custom rounded border class
class RoundedBorderPW extends AbstractBorder {
    private int radius;
    private Color color;

    public RoundedBorderPW(int radius, Color color) {
        this.radius = radius;
        this.color = color;
    }

    @Override
    public void paintBorder(Component c, Graphics g, int x, int y, int width, int height) {
        Graphics2D g2d = (Graphics2D) g;
        g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2d.setColor(color);
        g2d.setStroke(new BasicStroke(2));
        g2d.drawRoundRect(x, y, width - 1, height - 1, radius, radius);
    }

    @Override
    public Insets getBorderInsets(Component c) {
        return new Insets(2, 2, 2, 2);
    }
}
